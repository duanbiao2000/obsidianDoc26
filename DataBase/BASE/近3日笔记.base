filters:
  and:
    - and:
        - file.ext == "md"
        - file.mtime >= today() - duration("3d")
views:
  - type: table
    name: Table
    order:
      - file.name
      - file.mtime
      - file.path
    sort:
      - property: file.mtime
        direction: DESC
    columnSize:
      file.name: 260
